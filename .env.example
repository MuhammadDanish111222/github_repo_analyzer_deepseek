# Required
DEEPSEEK_API_KEY=replace-with-your-deepseek-key

# DeepSeek official OpenAI-compatible endpoint
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_THINKING_TYPE=disabled

# Optional but recommended for better GitHub API rate limits
GITHUB_TOKEN=

# App settings
APP_NAME=Live GitHub Repository Analyzer API
APP_ENV=development
REQUEST_TIMEOUT_SECONDS=25
MAX_SOURCE_FILE_BYTES=200000
MAX_CODE_CHARS_FOR_LLM=80000
LOG_LEVEL=INFO

# Render supplies PORT automatically. Keep default for local Docker.
PORT=10000
